  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office          Office?                    @relation(fields: [officeId], references: [id], onDelete: SetNull)
  assignments     CommissionPlanAssignment[]
  rules           CommissionPlanRule[]
  calculations    CommissionCalculation[]

  @@unique([organizationId, officeId, name])
  @@index([organizationId, officeId, isActive])
}

model CommissionPlanAssignment {
  id               String         @id @default(cuid())
  organizationId   String
  officeId         String?
  membershipId     String?
  teamId           String?
  commissionPlanId String
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office           Office?        @relation(fields: [officeId], references: [id], onDelete: SetNull)
  membership       Membership?    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  team             Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  commissionPlan   CommissionPlan @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)

  @@index([organizationId, officeId, membershipId])
  @@index([organizationId, officeId, teamId])
  @@index([organizationId, commissionPlanId])
  @@index([organizationId, effectiveFrom, effectiveTo])
}

model CommissionPlanRule {
  id               String                   @id @default(cuid())
  organizationId   String
  commissionPlanId String
  ruleType         CommissionPlanRuleType
  ruleName         String
  sortOrder        Int                      @default(0)
  splitPercent     Decimal?                 @db.Decimal(7, 4)
  flatAmount       Decimal?                 @db.Decimal(12, 2)
  feeType          CommissionRuleFeeType?
  feeAmount        Decimal?                 @db.Decimal(12, 2)
  thresholdStart   Decimal?                 @db.Decimal(12, 2)
  thresholdEnd     Decimal?                 @db.Decimal(12, 2)
  appliesToRole    String?
  recipientType    CommissionRecipientType?
  isActive         Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commissionPlan   CommissionPlan           @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)

  @@index([organizationId, commissionPlanId, sortOrder])
  @@index([organizationId, ruleType, isActive])
}

model CommissionCalculation {
  id                       String                      @id @default(cuid())
  organizationId           String
  officeId                 String?
  transactionId            String
  membershipId             String?
  commissionPlanId         String?
  accountingTransactionId  String?
  recipientType            CommissionRecipientType
  recipientRole            String?
  recipientName            String?
  grossCommission          Decimal                     @default(0) @db.Decimal(12, 2)
  referralFee              Decimal                     @default(0) @db.Decimal(12, 2)
  fees                     Decimal                     @default(0) @db.Decimal(12, 2)
  officeNet                Decimal                     @default(0) @db.Decimal(12, 2)
  agentNet                 Decimal                     @default(0) @db.Decimal(12, 2)
  statementAmount          Decimal                     @default(0) @db.Decimal(12, 2)
  status                   CommissionCalculationStatus @default(draft)
  notes                    String?
  calculatedAt             DateTime                    @default(now())
  calculatedByMembershipId String?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  organization             Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                   Office?                     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction              Transaction                 @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  membership               Membership?                 @relation("CommissionCalculationMembership", fields: [membershipId], references: [id], onDelete: SetNull)
  commissionPlan           CommissionPlan?             @relation(fields: [commissionPlanId], references: [id], onDelete: SetNull)
  accountingTransaction    AccountingTransaction?      @relation(fields: [accountingTransactionId], references: [id], onDelete: SetNull)
  calculatedByMembership   Membership?                 @relation("CommissionCalculationCalculatedBy", fields: [calculatedByMembershipId], references: [id], onDelete: SetNull)

  @@index([organizationId, officeId, status])
  @@index([organizationId, transactionId])
  @@index([organizationId, membershipId])
  @@index([organizationId, commissionPlanId])
  @@index([organizationId, calculatedAt])
}

model EarnestMoneyRecord {
  id                    String             @id @default(cuid())
  organizationId        String
  officeId              String?
  transactionId         String
  expectedAmount        Decimal            @db.Decimal(12, 2)
  dueAt                 DateTime
  receivedAmount        Decimal            @default(0) @db.Decimal(12, 2)
  refundedAmount        Decimal            @default(0) @db.Decimal(12, 2)
  paymentDate           DateTime?
  depositDate           DateTime?
  heldByOffice          Boolean            @default(true)
  heldExternally        Boolean            @default(false)
  trackInLedger         Boolean            @default(true)
  status                EarnestMoneyStatus @default(not_received)
  notes                 String?
  createdByMembershipId String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction           Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdByMembership   Membership?        @relation("EarnestMoneyCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  @@unique([transactionId])
  @@index([organizationId, officeId, status])
  @@index([organizationId, dueAt])
}

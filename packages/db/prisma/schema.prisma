generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  agent
  office_manager
  office_admin
}

enum MembershipStatus {
  active
  invited
  disabled
}

enum ListingStatus {
  draft
  active
  hot
  pending
  off_market
  sold
}

enum TaskStatus {
  queued
  in_progress
  completed
  canceled
}

enum NotificationType {
  system
  listing
  follow_up
  event
}

enum EventVisibility {
  all_agents
  office_only
  invite_only
}

enum RsvpStatus {
  going
  maybe
  declined
}

enum ResourceType {
  training_video
  vendor_card
  document
  template
  playbook
}

enum LibraryDocumentVisibility {
  company_wide
  office_only
}

enum TransactionType {
  sales
  sales_listing
  rental_leasing
  rental_listing
  commercial_sales
  commercial_lease
  other
}

enum TransactionStatus {
  opportunity
  active
  pending
  closed
  cancelled
}

enum TransactionRepresenting {
  buyer
  seller
  both
  tenant
  landlord
}

enum TransactionContactRole {
  buyer
  seller
  co_buyer
  co_seller
  tenant
  landlord
  other
}

enum TransactionTaskStatus {
  todo
  in_progress
  review_requested
  completed
  reopened
}

enum TransactionTaskReviewStatus {
  not_required
  pending
  review_requested
  first_approved
  second_review
  approved
  rejected
}

enum TransactionTaskComplianceStatus {
  not_applicable
  pending
  in_review
  approved
  rejected
}

enum TransactionDocumentStatus {
  uploaded
  submitted
  approved
  rejected
  signed
  archived
}

enum TransactionDocumentSource {
  manual_upload
  generated_form
  incoming_update
  synced_external
  email_pdf
}

enum TransactionFormStatus {
  draft
  prepared
  sent_for_signature
  partially_signed
  fully_signed
  rejected
  voided
}

enum SignatureRequestStatus {
  draft
  sent
  viewed
  signed
  declined
  canceled
}

enum IncomingUpdateStatus {
  pending_review
  accepted
  rejected
  applied
}

enum OfferStatus {
  draft
  submitted
  received
  under_review
  countered
  accepted
  rejected
  withdrawn
  expired
}

enum LedgerAccountType {
  asset
  liability
  equity
  income
  expense
  contra_income
  contra_expense
}

enum AccountingTransactionType {
  invoice
  bill
  credit_memo
  deposit
  received_payment
  made_payment
  journal_entry
  transfer
  refund
}

enum AccountingTransactionStatus {
  draft
  open
  posted
  completed
  void
}

enum AccountingLineEntrySide {
  debit
  credit
}

enum AccountingPaymentMethod {
  ach
  check
  wire
  cash
  internal_transfer
  other
}

enum AgentBillingFrequency {
  monthly
  quarterly
  annual
  custom_interval
}

enum AgentPaymentMethodType {
  card_on_file
  bank_account
  check
  manual
  other
}

enum AgentPaymentMethodStatus {
  active
  inactive
  invalid
  expired
  removed
}

enum AgentOnboardingStatus {
  not_started
  in_progress
  complete
}

enum TeamMembershipRole {
  lead
  member
}

enum AgentOnboardingItemStatus {
  pending
  in_progress
  completed
  reopened
}

enum AgentGoalPeriodType {
  monthly
  quarterly
  annual
}

enum TransactionFieldKey {
  price
  important_date
  closing_date
  buyer_expiration_date
  acceptance_date
  company_referral
  company_referral_employee_name
}

enum CommissionCalculationMode {
  split_and_fees
  flat_net
}

enum CommissionPlanRuleType {
  base_split
  brokerage_fee
  referral_fee
  flat_fee_deduction
  sliding_scale
}

enum CommissionRuleFeeType {
  percentage
  flat
}

enum CommissionRecipientType {
  agent
  brokerage
  referral
}

enum CommissionCalculationStatus {
  draft
  calculated
  reviewed
  statement_ready
  payable
  paid
}

enum EarnestMoneyStatus {
  not_received
  overdue
  pending_bank_deposit
  fully_deposited
  distribute_balance
  complete
}

model Organization {
  id                                String                             @id @default(cuid())
  name                              String
  slug                              String                             @unique
  timezone                          String                             @default("America/New_York")
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  offices                           Office[]
  memberships                       Membership[]
  listings                          Listing[]
  clients                           Client[]
  followUpTasks                     FollowUpTask[]
  notifications                     Notification[]
  events                            Event[]
  resources                         Resource[]
  vendors                           Vendor[]
  libraryFolders                    LibraryFolder[]
  libraryDocuments                  LibraryDocument[]
  auditLogs                         AuditLog[]
  transactions                      Transaction[]
  transactionContacts               TransactionContact[]
  transactionTasks                  TransactionTask[]
  taskListViews                     TaskListView[]
  ledgerAccounts                    LedgerAccount[]
  accountingTransactions            AccountingTransaction[]
  accountingTransactionLineItems    AccountingTransactionLineItem[]
  accountingTransactionApplications AccountingTransactionApplication[]
  generalLedgerEntries              GeneralLedgerEntry[]
  earnestMoneyRecords               EarnestMoneyRecord[]
  agentRecurringChargeRules         AgentRecurringChargeRule[]
  agentPaymentMethods               AgentPaymentMethod[]
  transactionDocuments              TransactionDocument[]
  formTemplates                     FormTemplate[]
  transactionForms                  TransactionForm[]
  signatureRequests                 SignatureRequest[]
  incomingUpdates                   IncomingUpdate[]
  offers                            Offer[]
  offerComments                     OfferComment[]
  agentProfiles                     AgentProfile[]
  teams                             Team[]
  teamMemberships                   TeamMembership[]
  agentOnboardingTemplateItems      AgentOnboardingTemplateItem[]
  agentOnboardingItems              AgentOnboardingItem[]
  agentGoals                        AgentGoal[]
  commissionPlans                   CommissionPlan[]
  commissionPlanAssignments         CommissionPlanAssignment[]
  commissionPlanRules               CommissionPlanRule[]
  commissionCalculations            CommissionCalculation[]
  requiredContactRoleSettings       RequiredContactRoleSetting[]
  transactionFieldSettings          TransactionFieldSetting[]
  checklistTemplates                ChecklistTemplate[]
  checklistTemplateItems            ChecklistTemplateItem[]
}

model Office {
  id                                String                             @id @default(cuid())
  organizationId                    String
  name                              String
  slug                              String
  market                            String
  isPrimary                         Boolean                            @default(false)
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  organization                      Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships                       Membership[]
  listings                          Listing[]
  events                            Event[]
  resources                         Resource[]
  vendors                           Vendor[]
  libraryFolders                    LibraryFolder[]
  libraryDocuments                  LibraryDocument[]
  transactions                      Transaction[]
  taskListViews                     TaskListView[]
  ledgerAccounts                    LedgerAccount[]
  accountingTransactions            AccountingTransaction[]
  accountingTransactionLineItems    AccountingTransactionLineItem[]
  accountingTransactionApplications AccountingTransactionApplication[]
  generalLedgerEntries              GeneralLedgerEntry[]
  earnestMoneyRecords               EarnestMoneyRecord[]
  agentRecurringChargeRules         AgentRecurringChargeRule[]
  agentPaymentMethods               AgentPaymentMethod[]
  transactionDocuments              TransactionDocument[]
  formTemplates                     FormTemplate[]
  transactionForms                  TransactionForm[]
  signatureRequests                 SignatureRequest[]
  incomingUpdates                   IncomingUpdate[]
  offers                            Offer[]
  offerComments                     OfferComment[]
  agentProfiles                     AgentProfile[]
  teams                             Team[]
  teamMemberships                   TeamMembership[]
  agentOnboardingTemplateItems      AgentOnboardingTemplateItem[]
  agentOnboardingItems              AgentOnboardingItem[]
  agentGoals                        AgentGoal[]
  commissionPlans                   CommissionPlan[]
  commissionPlanAssignments         CommissionPlanAssignment[]
  commissionCalculations            CommissionCalculation[]
  requiredContactRoleSettings       RequiredContactRoleSetting[]
  transactionFieldSettings          TransactionFieldSetting[]
  checklistTemplates                ChecklistTemplate[]
  checklistTemplateItems            ChecklistTemplateItem[]

  @@unique([organizationId, slug])
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  firstName   String
  lastName    String
  timezone    String       @default("America/New_York")
  locale      String       @default("en-US")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id                                       String                             @id @default(cuid())
  organizationId                           String
  officeId                                 String?
  userId                                   String
  role                                     UserRole
  status                                   MembershipStatus                   @default(active)
  title                                    String?
  permissions                              Json?
  createdAt                                DateTime                           @default(now())
  updatedAt                                DateTime                           @updatedAt
  organization                             Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                                   Office?                            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  user                                     User                               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingsOwned                            Listing[]
  clientsOwned                             Client[]
  tasksAssigned                            FollowUpTask[]
  notifications                            Notification[]
  eventsCreated                            Event[]
  eventRsvps                               EventRsvp[]
  auditLogs                                AuditLog[]
  transactionsOwned                        Transaction[]
  transactionTasksAssigned                 TransactionTask[]                  @relation("TransactionTaskAssignee")
  transactionTasksCompleted                TransactionTask[]                  @relation("TransactionTaskCompletedBy")
  transactionTasksSubmittedForReview       TransactionTask[]                  @relation("TransactionTaskSubmittedForReviewBy")
  transactionTasksFirstApproved            TransactionTask[]                  @relation("TransactionTaskFirstApprovedBy")
  transactionTasksSecondApproved           TransactionTask[]                  @relation("TransactionTaskSecondApprovedBy")
  transactionTasksRejected                 TransactionTask[]                  @relation("TransactionTaskRejectedBy")
  taskListViews                            TaskListView[]
  accountingTransactionsCreated            AccountingTransaction[]            @relation("AccountingTransactionCreatedBy")
  accountingTransactionsRelated            AccountingTransaction[]            @relation("AccountingTransactionRelatedMembership")
  accountingTransactionApplicationsCreated AccountingTransactionApplication[] @relation("AccountingTransactionApplicationCreatedBy")
  earnestMoneyRecordsCreated               EarnestMoneyRecord[]               @relation("EarnestMoneyCreatedBy")
  agentRecurringChargeRules                AgentRecurringChargeRule[]         @relation("AgentRecurringChargeRuleMembership")
  agentPaymentMethods                      AgentPaymentMethod[]
  createdLibraryFolders                    LibraryFolder[]                    @relation("LibraryFolderCreatedBy")
  uploadedTransactionDocuments             TransactionDocument[]              @relation("TransactionDocumentUploadedBy")
  uploadedLibraryDocuments                 LibraryDocument[]                  @relation("LibraryDocumentUploadedBy")
  createdTransactionForms                  TransactionForm[]                  @relation("TransactionFormCreatedBy")
  requestedSignatureRequests               SignatureRequest[]                 @relation("SignatureRequestRequestedBy")
  reviewedIncomingUpdates                  IncomingUpdate[]                   @relation("IncomingUpdateReviewedBy")
  createdOffers                            Offer[]                            @relation("OfferCreatedBy")
  offerComments                            OfferComment[]
  agentProfile                             AgentProfile?
  teamMemberships                          TeamMembership[]
  agentOnboardingItems                     AgentOnboardingItem[]
  completedAgentOnboardingItems            AgentOnboardingItem[]              @relation("AgentOnboardingCompletedBy")
  agentGoals                               AgentGoal[]
  commissionPlanAssignments                CommissionPlanAssignment[]
  commissionCalculations                   CommissionCalculation[]            @relation("CommissionCalculationMembership")
  calculatedCommissionCalculations         CommissionCalculation[]            @relation("CommissionCalculationCalculatedBy")
  checklistTemplatesCreated                ChecklistTemplate[]                @relation("ChecklistTemplateCreatedBy")
  checklistTemplatesUpdated                ChecklistTemplate[]                @relation("ChecklistTemplateUpdatedBy")

  @@unique([organizationId, userId])
}

model Transaction {
  id                             String                          @id @default(cuid())
  organizationId                 String
  officeId                       String?
  ownerMembershipId              String?
  primaryClientId                String?
  type                           TransactionType
  status                         TransactionStatus               @default(opportunity)
  representing                   TransactionRepresenting
  title                          String
  address                        String
  city                           String
  state                          String
  zipCode                        String
  price                          Decimal?                        @db.Decimal(12, 2)
  importantDate                  DateTime?
  buyerAgreementDate             DateTime?
  buyerExpirationDate            DateTime?
  acceptanceDate                 DateTime?
  listingDate                    DateTime?
  listingExpirationDate          DateTime?
  closingDate                    DateTime?
  companyReferral                Boolean                         @default(false)
  companyReferralEmployeeName    String?
  referralContext                Json?
  grossCommission                Decimal?                        @db.Decimal(12, 2)
  referralFee                    Decimal?                        @db.Decimal(12, 2)
  officeNet                      Decimal?                        @db.Decimal(12, 2)
  agentNet                       Decimal?                        @db.Decimal(12, 2)
  financeNotes                   String?
  commissionContext              Json?
  additionalFields               Json?
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  organization                   Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                         Office?                         @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerMembership                Membership?                     @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  primaryClient                  Client?                         @relation("TransactionPrimaryClient", fields: [primaryClientId], references: [id], onDelete: SetNull)
  transactionContacts            TransactionContact[]
  tasks                          TransactionTask[]
  accountingTransactions         AccountingTransaction[]
  accountingTransactionLineItems AccountingTransactionLineItem[]
  generalLedgerEntries           GeneralLedgerEntry[]
  earnestMoneyRecords            EarnestMoneyRecord[]
  documents                      TransactionDocument[]
  forms                          TransactionForm[]
  signatureRequests              SignatureRequest[]
  incomingUpdates                IncomingUpdate[]
  offers                         Offer[]
  commissionCalculations         CommissionCalculation[]

  @@index([organizationId, status])
  @@index([organizationId, officeId])
  @@index([organizationId, ownerMembershipId])
  @@index([organizationId, primaryClientId])
}

model Listing {
  id                String             @id @default(cuid())
  organizationId    String
  officeId          String?
  ownerMembershipId String?
  title             String
  slug              String
  sourceUrl         String?
  status            ListingStatus      @default(draft)
  price             Decimal?           @db.Decimal(12, 2)
  city              String
  neighborhood      String
  bedrooms          Int?
  bathrooms         Decimal?           @db.Decimal(4, 1)
  isPublic          Boolean            @default(false)
  heroFacts         Json?
  seoKeywords       String[]
  aiSummary         String?
  parsedJson        Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office            Office?            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerMembership   Membership?        @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  assets            ListingAsset[]
  shareLinks        ListingShareLink[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, isPublic])
}

model ListingAsset {
  id        String   @id @default(cuid())
  listingId String
  assetType String
  label     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingShareLink {
  id           String   @id @default(cuid())
  listingId    String
  membershipId String?
  channel      String
  code         String   @unique
  targetUrl    String
  clickCount   Int      @default(0)
  qrAssetUrl   String?
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Client {
  id                  String               @id @default(cuid())
  organizationId      String
  ownerMembershipId   String?
  fullName            String
  email               String?
  phone               String?
  contactType         String?
  source              String
  stage               String
  intent              String
  budgetMin           Decimal?             @db.Decimal(12, 2)
  budgetMax           Decimal?             @db.Decimal(12, 2)
  preferredAreas      String[]
  needsSummary        Json?
  notes               String?
  lastContactAt       DateTime?
  nextFollowUpAt      DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerMembership     Membership?          @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  followUpTasks       FollowUpTask[]
  primaryTransactions Transaction[]        @relation("TransactionPrimaryClient")
  transactionContacts TransactionContact[]

  @@index([organizationId, stage])
}

model TransactionContact {
  id             String                 @id @default(cuid())
  organizationId String
  transactionId  String
  clientId       String
  role           TransactionContactRole @default(other)
  isPrimary      Boolean                @default(false)
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction    Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  client         Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([transactionId, clientId])
  @@index([organizationId, transactionId])
  @@index([organizationId, clientId])
  @@index([organizationId, transactionId, isPrimary])
}

model TransactionTask {
  id                               String                          @id @default(cuid())
  organizationId                   String
  transactionId                    String
  checklistGroup                   String                          @default("General")
  title                            String
  description                      String?
  assigneeMembershipId             String?
  dueAt                            DateTime?
  status                           TransactionTaskStatus           @default(todo)
  requiresDocument                 Boolean                         @default(false)
  requiresDocumentApproval         Boolean                         @default(false)
  requiresSecondaryApproval        Boolean                         @default(false)
  reviewStatus                     TransactionTaskReviewStatus     @default(not_required)
  complianceStatus                 TransactionTaskComplianceStatus @default(not_applicable)
  sortOrder                        Int                             @default(0)
  completedAt                      DateTime?
  completedByMembershipId          String?
  submittedForReviewAt             DateTime?
  submittedForReviewByMembershipId String?
  firstApprovedAt                  DateTime?
  firstApprovedByMembershipId      String?
  secondApprovedAt                 DateTime?
  secondApprovedByMembershipId     String?
  rejectedAt                       DateTime?
  rejectedByMembershipId           String?
  rejectionReason                  String?
  reopenedAt                       DateTime?
  createdAt                        DateTime                        @default(now())
  updatedAt                        DateTime                        @updatedAt
  organization                     Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction                      Transaction                     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assigneeMembership               Membership?                     @relation("TransactionTaskAssignee", fields: [assigneeMembershipId], references: [id], onDelete: SetNull)
  completedByMembership            Membership?                     @relation("TransactionTaskCompletedBy", fields: [completedByMembershipId], references: [id], onDelete: SetNull)
  submittedForReviewByMembership   Membership?                     @relation("TransactionTaskSubmittedForReviewBy", fields: [submittedForReviewByMembershipId], references: [id], onDelete: SetNull)
  firstApprovedByMembership        Membership?                     @relation("TransactionTaskFirstApprovedBy", fields: [firstApprovedByMembershipId], references: [id], onDelete: SetNull)
  secondApprovedByMembership       Membership?                     @relation("TransactionTaskSecondApprovedBy", fields: [secondApprovedByMembershipId], references: [id], onDelete: SetNull)
  rejectedByMembership             Membership?                     @relation("TransactionTaskRejectedBy", fields: [rejectedByMembershipId], references: [id], onDelete: SetNull)
  documents                        TransactionDocument[]
  forms                            TransactionForm[]

  @@index([organizationId, transactionId])
  @@index([organizationId, assigneeMembershipId])
  @@index([organizationId, transactionId, status])
  @@index([organizationId, transactionId, sortOrder])
  @@index([organizationId, dueAt])
  @@index([organizationId, complianceStatus])
  @@index([organizationId, reviewStatus])
}

model TaskListView {
  id             String       @id @default(cuid())
  organizationId String
  officeId       String?
  membershipId   String
  name           String
  isSystem       Boolean      @default(false)
  isShared       Boolean      @default(false)
  filters        Json
  visibleColumns Json?
  sort           Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
  membership     Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([organizationId, membershipId, name])
  @@index([organizationId, membershipId, officeId])
}

model FollowUpTask {
  id                 String         @id @default(cuid())
  organizationId     String
  clientId           String?
  assigneeMemberId   String?
  title              String
  status             TaskStatus     @default(queued)
  dueAt              DateTime?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assigneeMembership Membership?    @relation(fields: [assigneeMemberId], references: [id], onDelete: SetNull)
  notifications      Notification[]

  @@index([organizationId, status])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  membershipId   String?
  followUpTaskId String?
  eventId        String?
  type           NotificationType
  title          String
  body           String
  actionUrl      String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership     Membership?      @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  followUpTask   FollowUpTask?    @relation(fields: [followUpTaskId], references: [id], onDelete: SetNull)
  event          Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
}

model Event {
  id                  String          @id @default(cuid())
  organizationId      String
  officeId            String?
  createdByMemberId   String?
  title               String
  description         String
  visibility          EventVisibility @default(all_agents)
  startsAt            DateTime
  endsAt              DateTime?
  location            String?
  meetingUrl          String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office              Office?         @relation(fields: [officeId], references: [id], onDelete: SetNull)
  createdByMembership Membership?     @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)
  rsvps               EventRsvp[]
  notifications       Notification[]

  @@index([organizationId, startsAt])
}

model EventRsvp {
  id           String     @id @default(cuid())
  eventId      String
  membershipId String
  status       RsvpStatus
  respondedAt  DateTime   @default(now())
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([eventId, membershipId])
}

model Resource {
  id             String       @id @default(cuid())
  organizationId String
  officeId       String?
  type           ResourceType
  title          String
  slug           String
  summary        String
  url            String
  tags           String[]
  isPublished    Boolean      @default(true)
  searchText     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
}

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  officeId       String?
  category       String
  name           String
  headline       String
  phone          String?
  email          String?
  website        String?
  neighborhoods  String[]
  notes          String?
  isFeatured     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
}

model LibraryFolder {
  id                    String            @id @default(cuid())
  organizationId        String
  officeId              String?
  parentFolderId        String?
  createdByMembershipId String?
  name                  String
  description           String?
  sortOrder             Int               @default(0)
  isActive              Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?           @relation(fields: [officeId], references: [id], onDelete: SetNull)
  parentFolder          LibraryFolder?    @relation("LibraryFolderParent", fields: [parentFolderId], references: [id], onDelete: SetNull)
  childFolders          LibraryFolder[]   @relation("LibraryFolderParent")
  createdByMembership   Membership?       @relation("LibraryFolderCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: SetNull)
  documents             LibraryDocument[]

  @@index([organizationId, officeId, isActive, sortOrder])
  @@index([organizationId, parentFolderId, isActive, sortOrder])
}

model LibraryDocument {
  id                     String                    @id @default(cuid())
  organizationId         String
  officeId               String?
  folderId               String?
  uploadedByMembershipId String?
  title                  String
  originalFileName       String
  mimeType               String
  fileSizeBytes          Int
  storageKey             String
  pageCount              Int?
  summary                String?
  tags                   String[]
  category               String?
  visibility             LibraryDocumentVisibility @default(company_wide)
  sortOrder              Int                       @default(0)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  agent
  office_manager
  office_admin
}

enum MembershipStatus {
  active
  invited
  disabled
}

enum ListingStatus {
  draft
  active
  hot
  pending
  off_market
  sold
}

enum TaskStatus {
  queued
  in_progress
  completed
  canceled
}

enum NotificationType {
  system
  listing
  follow_up
  event
}

enum EventVisibility {
  all_agents
  office_only
  invite_only
}

enum RsvpStatus {
  going
  maybe
  declined
}

enum ResourceType {
  training_video
  vendor_card
  document
  template
  playbook
}

enum TransactionType {
  sales
  sales_listing
  rental_leasing
  rental_listing
  commercial_sales
  commercial_lease
  other
}

enum TransactionStatus {
  opportunity
  active
  pending
  closed
  cancelled
}

enum TransactionRepresenting {
  buyer
  seller
  both
  tenant
  landlord
}

enum TransactionContactRole {
  buyer
  seller
  co_buyer
  co_seller
  tenant
  landlord
  other
}

enum TransactionTaskStatus {
  todo
  in_progress
  review_requested
  completed
  reopened
}

enum TransactionTaskReviewStatus {
  not_required
  pending
  review_requested
  first_approved
  second_review
  approved
  rejected
}

enum TransactionTaskComplianceStatus {
  not_applicable
  pending
  in_review
  approved
  rejected
}

enum TransactionDocumentStatus {
  uploaded
  submitted
  approved
  rejected
  signed
  archived
}

enum TransactionDocumentSource {
  manual_upload
  generated_form
  incoming_update
  synced_external
  email_pdf
}

enum TransactionFormStatus {
  draft
  prepared
  sent_for_signature
  partially_signed
  fully_signed
  rejected
  voided
}

enum SignatureRequestStatus {
  draft
  sent
  viewed
  signed
  declined
  canceled
}

enum IncomingUpdateStatus {
  pending_review
  accepted
  rejected
  applied
}

enum LedgerAccountType {
  asset
  liability
  equity
  income
  expense
  contra_income
  contra_expense
}

enum AccountingTransactionType {
  invoice
  bill
  credit_memo
  deposit
  received_payment
  made_payment
  journal_entry
  transfer
  refund
}

enum AccountingTransactionStatus {
  draft
  open
  posted
  completed
  void
}

enum AccountingLineEntrySide {
  debit
  credit
}

enum AccountingPaymentMethod {
  ach
  check
  wire
  cash
  internal_transfer
  other
}

enum EarnestMoneyStatus {
  not_received
  overdue
  pending_bank_deposit
  fully_deposited
  distribute_balance
  complete
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  timezone      String         @default("America/New_York")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  offices       Office[]
  memberships   Membership[]
  listings      Listing[]
  clients       Client[]
  followUpTasks FollowUpTask[]
  notifications Notification[]
  events        Event[]
  resources     Resource[]
  vendors       Vendor[]
  auditLogs     AuditLog[]
  transactions  Transaction[]
  transactionContacts TransactionContact[]
  transactionTasks TransactionTask[]
  taskListViews TaskListView[]
  ledgerAccounts LedgerAccount[]
  accountingTransactions AccountingTransaction[]
  accountingTransactionLineItems AccountingTransactionLineItem[]
  generalLedgerEntries GeneralLedgerEntry[]
  earnestMoneyRecords EarnestMoneyRecord[]
  transactionDocuments TransactionDocument[]
  formTemplates FormTemplate[]
  transactionForms TransactionForm[]
  signatureRequests SignatureRequest[]
  incomingUpdates IncomingUpdate[]
}

model Office {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  slug           String
  market         String
  isPrimary      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  listings       Listing[]
  events         Event[]
  resources      Resource[]
  vendors        Vendor[]
  transactions   Transaction[]
  taskListViews  TaskListView[]
  ledgerAccounts LedgerAccount[]
  accountingTransactions AccountingTransaction[]
  accountingTransactionLineItems AccountingTransactionLineItem[]
  generalLedgerEntries GeneralLedgerEntry[]
  earnestMoneyRecords EarnestMoneyRecord[]
  transactionDocuments TransactionDocument[]
  formTemplates FormTemplate[]
  transactionForms TransactionForm[]
  signatureRequests SignatureRequest[]
  incomingUpdates IncomingUpdate[]

  @@unique([organizationId, slug])
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  firstName   String
  lastName    String
  timezone    String       @default("America/New_York")
  locale      String       @default("en-US")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id                String            @id @default(cuid())
  organizationId    String
  officeId          String?
  userId            String
  role              UserRole
  status            MembershipStatus  @default(active)
  title             String?
  permissions       Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office            Office?           @relation(fields: [officeId], references: [id], onDelete: SetNull)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingsOwned     Listing[]
  clientsOwned      Client[]
  tasksAssigned     FollowUpTask[]
  notifications     Notification[]
  eventsCreated     Event[]
  eventRsvps        EventRsvp[]
  auditLogs         AuditLog[]
  transactionsOwned Transaction[]
  transactionTasksAssigned TransactionTask[]         @relation("TransactionTaskAssignee")
  transactionTasksCompleted TransactionTask[]        @relation("TransactionTaskCompletedBy")
  transactionTasksFirstApproved TransactionTask[]    @relation("TransactionTaskFirstApprovedBy")
  transactionTasksSecondApproved TransactionTask[]   @relation("TransactionTaskSecondApprovedBy")
  transactionTasksRejected TransactionTask[]         @relation("TransactionTaskRejectedBy")
  taskListViews TaskListView[]
  accountingTransactionsCreated AccountingTransaction[] @relation("AccountingTransactionCreatedBy")
  accountingTransactionsRelated AccountingTransaction[] @relation("AccountingTransactionRelatedMembership")
  earnestMoneyRecordsCreated EarnestMoneyRecord[] @relation("EarnestMoneyCreatedBy")
  uploadedTransactionDocuments TransactionDocument[] @relation("TransactionDocumentUploadedBy")
  createdTransactionForms TransactionForm[] @relation("TransactionFormCreatedBy")
  requestedSignatureRequests SignatureRequest[] @relation("SignatureRequestRequestedBy")
  reviewedIncomingUpdates IncomingUpdate[] @relation("IncomingUpdateReviewedBy")

  @@unique([organizationId, userId])
}

model Transaction {
  id                          String                   @id @default(cuid())
  organizationId              String
  officeId                    String?
  ownerMembershipId           String?
  primaryClientId             String?
  type                        TransactionType
  status                      TransactionStatus        @default(opportunity)
  representing                TransactionRepresenting
  title                       String
  address                     String
  city                        String
  state                       String
  zipCode                     String
  price                       Decimal?                 @db.Decimal(12, 2)
  importantDate               DateTime?
  buyerAgreementDate          DateTime?
  buyerExpirationDate         DateTime?
  acceptanceDate              DateTime?
  listingDate                 DateTime?
  listingExpirationDate       DateTime?
  closingDate                 DateTime?
  companyReferral             Boolean                  @default(false)
  companyReferralEmployeeName String?
  referralContext             Json?
  grossCommission             Decimal?                 @db.Decimal(12, 2)
  referralFee                 Decimal?                 @db.Decimal(12, 2)
  officeNet                   Decimal?                 @db.Decimal(12, 2)
  agentNet                    Decimal?                 @db.Decimal(12, 2)
  financeNotes                String?
  commissionContext           Json?
  additionalFields            Json?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  organization                Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                      Office?                  @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerMembership             Membership?              @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  primaryClient               Client?                  @relation("TransactionPrimaryClient", fields: [primaryClientId], references: [id], onDelete: SetNull)
  transactionContacts         TransactionContact[]
  tasks                       TransactionTask[]
  accountingTransactions      AccountingTransaction[]
  accountingTransactionLineItems AccountingTransactionLineItem[]
  generalLedgerEntries        GeneralLedgerEntry[]
  earnestMoneyRecords         EarnestMoneyRecord[]
  documents                   TransactionDocument[]
  forms                       TransactionForm[]
  signatureRequests           SignatureRequest[]
  incomingUpdates             IncomingUpdate[]

  @@index([organizationId, status])
  @@index([organizationId, officeId])
  @@index([organizationId, ownerMembershipId])
  @@index([organizationId, primaryClientId])
}

model Listing {
  id                String             @id @default(cuid())
  organizationId    String
  officeId          String?
  ownerMembershipId String?
  title             String
  slug              String
  sourceUrl         String?
  status            ListingStatus      @default(draft)
  price             Decimal?           @db.Decimal(12, 2)
  city              String
  neighborhood      String
  bedrooms          Int?
  bathrooms         Decimal?           @db.Decimal(4, 1)
  isPublic          Boolean            @default(false)
  heroFacts         Json?
  seoKeywords       String[]
  aiSummary         String?
  parsedJson        Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office            Office?            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerMembership   Membership?        @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  assets            ListingAsset[]
  shareLinks        ListingShareLink[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, isPublic])
}

model ListingAsset {
  id         String   @id @default(cuid())
  listingId  String
  assetType  String
  label      String
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingShareLink {
  id           String    @id @default(cuid())
  listingId    String
  membershipId String?
  channel      String
  code         String    @unique
  targetUrl    String
  clickCount   Int       @default(0)
  qrAssetUrl   String?
  createdAt    DateTime  @default(now())
  listing      Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Client {
  id                String        @id @default(cuid())
  organizationId    String
  ownerMembershipId String?
  fullName          String
  email             String?
  phone             String?
  contactType       String?
  source            String
  stage             String
  intent            String
  budgetMin         Decimal?      @db.Decimal(12, 2)
  budgetMax         Decimal?      @db.Decimal(12, 2)
  preferredAreas    String[]
  needsSummary      Json?
  notes             String?
  lastContactAt     DateTime?
  nextFollowUpAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerMembership   Membership?   @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  followUpTasks     FollowUpTask[]
  primaryTransactions Transaction[]      @relation("TransactionPrimaryClient")
  transactionContacts TransactionContact[]

  @@index([organizationId, stage])
}

model TransactionContact {
  id             String                 @id @default(cuid())
  organizationId String
  transactionId  String
  clientId       String
  role           TransactionContactRole @default(other)
  isPrimary      Boolean                @default(false)
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction    Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  client         Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([transactionId, clientId])
  @@index([organizationId, transactionId])
  @@index([organizationId, clientId])
  @@index([organizationId, transactionId, isPrimary])
}

model TransactionTask {
  id                        String                          @id @default(cuid())
  organizationId            String
  transactionId             String
  checklistGroup            String                          @default("General")
  title                     String
  description               String?
  assigneeMembershipId      String?
  dueAt                     DateTime?
  status                    TransactionTaskStatus           @default(todo)
  requiresDocument          Boolean                         @default(false)
  requiresDocumentApproval  Boolean                         @default(false)
  requiresSecondaryApproval Boolean                         @default(false)
  reviewStatus              TransactionTaskReviewStatus     @default(not_required)
  complianceStatus          TransactionTaskComplianceStatus @default(not_applicable)
  sortOrder                 Int                             @default(0)
  completedAt               DateTime?
  completedByMembershipId   String?
  submittedForReviewAt      DateTime?
  firstApprovedAt           DateTime?
  firstApprovedByMembershipId String?
  secondApprovedAt          DateTime?
  secondApprovedByMembershipId String?
  rejectedAt                DateTime?
  rejectedByMembershipId    String?
  reopenedAt                DateTime?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt
  organization              Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction               Transaction                     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assigneeMembership        Membership?                     @relation("TransactionTaskAssignee", fields: [assigneeMembershipId], references: [id], onDelete: SetNull)
  completedByMembership     Membership?                     @relation("TransactionTaskCompletedBy", fields: [completedByMembershipId], references: [id], onDelete: SetNull)
  firstApprovedByMembership Membership?                     @relation("TransactionTaskFirstApprovedBy", fields: [firstApprovedByMembershipId], references: [id], onDelete: SetNull)
  secondApprovedByMembership Membership?                    @relation("TransactionTaskSecondApprovedBy", fields: [secondApprovedByMembershipId], references: [id], onDelete: SetNull)
  rejectedByMembership      Membership?                     @relation("TransactionTaskRejectedBy", fields: [rejectedByMembershipId], references: [id], onDelete: SetNull)
  documents                 TransactionDocument[]
  forms                     TransactionForm[]

  @@index([organizationId, transactionId])
  @@index([organizationId, assigneeMembershipId])
  @@index([organizationId, transactionId, status])
  @@index([organizationId, transactionId, sortOrder])
  @@index([organizationId, dueAt])
  @@index([organizationId, complianceStatus])
}

model TaskListView {
  id             String       @id @default(cuid())
  organizationId String
  officeId       String?
  membershipId   String
  name           String
  isSystem       Boolean      @default(false)
  isShared       Boolean      @default(false)
  filters        Json
  visibleColumns Json?
  sort           Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
  membership     Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([organizationId, membershipId, name])
  @@index([organizationId, membershipId, officeId])
}

model FollowUpTask {
  id                 String        @id @default(cuid())
  organizationId     String
  clientId           String?
  assigneeMemberId   String?
  title              String
  status             TaskStatus    @default(queued)
  dueAt              DateTime?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assigneeMembership Membership?   @relation(fields: [assigneeMemberId], references: [id], onDelete: SetNull)
  notifications      Notification[]

  @@index([organizationId, status])
}

model Notification {
  id                 String           @id @default(cuid())
  organizationId     String
  membershipId       String?
  followUpTaskId     String?
  eventId            String?
  type               NotificationType
  title              String
  body               String
  actionUrl          String?
  readAt             DateTime?
  createdAt          DateTime         @default(now())
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership         Membership?      @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  followUpTask       FollowUpTask?    @relation(fields: [followUpTaskId], references: [id], onDelete: SetNull)
  event              Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, type])
}

model Event {
  id                  String          @id @default(cuid())
  organizationId      String
  officeId            String?
  createdByMemberId   String?
  title               String
  description         String
  visibility          EventVisibility @default(all_agents)
  startsAt            DateTime
  endsAt              DateTime?
  location            String?
  meetingUrl          String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office              Office?         @relation(fields: [officeId], references: [id], onDelete: SetNull)
  createdByMembership Membership?     @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)
  rsvps               EventRsvp[]
  notifications       Notification[]

  @@index([organizationId, startsAt])
}

model EventRsvp {
  id           String      @id @default(cuid())
  eventId      String
  membershipId String
  status       RsvpStatus
  respondedAt  DateTime    @default(now())
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([eventId, membershipId])
}

model Resource {
  id             String        @id @default(cuid())
  organizationId String
  officeId       String?
  type           ResourceType
  title          String
  slug           String
  summary        String
  url            String
  tags           String[]
  isPublished    Boolean       @default(true)
  searchText     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?       @relation(fields: [officeId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
}

model Vendor {
  id             String        @id @default(cuid())
  organizationId String
  officeId       String?
  category       String
  name           String
  headline       String
  phone          String?
  email          String?
  website        String?
  neighborhoods  String[]
  notes          String?
  isFeatured     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?       @relation(fields: [officeId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String
  membershipId   String?
  entityType     String
  entityId       String
  action         String
  payload        Json?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership     Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType])
}

model TransactionDocument {
  id                   String                    @id @default(cuid())
  organizationId       String
  officeId             String?
  transactionId        String
  uploadedByMembershipId String?
  linkedTaskId         String?
  title                String
  fileName             String
  mimeType             String
  fileSizeBytes        Int
  storageKey           String
  storageUrl           String?
  documentType         String
  status               TransactionDocumentStatus @default(uploaded)
  source               TransactionDocumentSource @default(manual_upload)
  isRequired           Boolean                   @default(false)
  isSigned             Boolean                   @default(false)
  isUnsorted           Boolean                   @default(false)
  signedAt             DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office               Office?                   @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction          Transaction               @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploadedByMembership Membership?              @relation("TransactionDocumentUploadedBy", fields: [uploadedByMembershipId], references: [id], onDelete: SetNull)
  linkedTask           TransactionTask?          @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  forms                TransactionForm[]         @relation("TransactionFormDocument")
  signatureRequests    SignatureRequest[]        @relation("SignatureRequestDocument")

  @@index([organizationId, transactionId, status])
  @@index([organizationId, transactionId, isUnsorted])
  @@index([organizationId, linkedTaskId])
  @@index([organizationId, officeId])
}

model FormTemplate {
  id             String      @id @default(cuid())
  organizationId String?
  officeId       String?
  key            String      @unique
  name           String
  description    String?
  documentType   String
  mergeFields    Json
  isSystem       Boolean     @default(true)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transactionForms TransactionForm[]

  @@index([organizationId, officeId, isActive])
}

model TransactionForm {
  id                   String               @id @default(cuid())
  organizationId       String
  officeId             String?
  transactionId        String
  templateId           String?
  linkedTaskId         String?
  documentId           String?
  name                 String
  status               TransactionFormStatus @default(draft)
  generatedPayload     Json
  createdByMembershipId String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office               Office?              @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction          Transaction          @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  template             FormTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  linkedTask           TransactionTask?     @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  document             TransactionDocument? @relation("TransactionFormDocument", fields: [documentId], references: [id], onDelete: SetNull)
  createdByMembership  Membership           @relation("TransactionFormCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: Cascade)
  signatureRequests    SignatureRequest[]   @relation("SignatureRequestForm")

  @@index([organizationId, transactionId, status])
  @@index([organizationId, linkedTaskId])
  @@index([organizationId, officeId])
}

model SignatureRequest {
  id                   String                @id @default(cuid())
  organizationId       String
  officeId             String?
  transactionId        String
  formId               String?
  documentId           String?
  requestedByMembershipId String
  recipientName        String
  recipientEmail       String
  recipientRole        String
  signingOrder         Int?
  status               SignatureRequestStatus @default(draft)
  sentAt               DateTime?
  viewedAt             DateTime?
  completedAt          DateTime?
  declinedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office               Office?              @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction          Transaction          @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  form                 TransactionForm?     @relation("SignatureRequestForm", fields: [formId], references: [id], onDelete: SetNull)
  document             TransactionDocument? @relation("SignatureRequestDocument", fields: [documentId], references: [id], onDelete: SetNull)
  requestedByMembership Membership          @relation("SignatureRequestRequestedBy", fields: [requestedByMembershipId], references: [id], onDelete: Cascade)

  @@index([organizationId, transactionId, status])
  @@index([organizationId, officeId])
  @@index([organizationId, formId])
  @@index([organizationId, documentId])
}

model IncomingUpdate {
  id                   String               @id @default(cuid())
  organizationId       String
  officeId             String?
  transactionId        String?
  sourceSystem         String
  sourceReference      String
  status               IncomingUpdateStatus @default(pending_review)
  summary              String
  payload              Json
  receivedAt           DateTime             @default(now())
  reviewedAt           DateTime?
  reviewedByMembershipId String?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office               Office?              @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction          Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  reviewedByMembership Membership?          @relation("IncomingUpdateReviewedBy", fields: [reviewedByMembershipId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, transactionId])
  @@index([organizationId, officeId, receivedAt])
  @@unique([organizationId, sourceSystem, sourceReference])
}

model LedgerAccount {
  id             String           @id @default(cuid())
  organizationId String
  officeId       String?
  code           String?
  name           String
  accountType    LedgerAccountType
  isSystem       Boolean          @default(false)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office?          @relation(fields: [officeId], references: [id], onDelete: SetNull)
  lineItems      AccountingTransactionLineItem[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@unique([organizationId, code])
  @@index([organizationId, officeId, accountType])
  @@index([organizationId, isActive])
}

model AccountingTransaction {
  id                    String                      @id @default(cuid())
  organizationId        String
  officeId              String?
  relatedTransactionId  String?
  relatedMembershipId   String?
  type                  AccountingTransactionType
  status                AccountingTransactionStatus @default(draft)
  accountingDate        DateTime
  dueDate               DateTime?
  paymentMethod         AccountingPaymentMethod?
  referenceNumber       String?
  counterpartyName      String?
  memo                  String?
  notes                 String?
  totalAmount           Decimal                     @db.Decimal(12, 2)
  createdByMembershipId String
  postedAt              DateTime?
  externalSyncStatus    String?
  externalReferenceId   String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?                     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  relatedTransaction    Transaction?                @relation(fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  relatedMembership     Membership?                 @relation("AccountingTransactionRelatedMembership", fields: [relatedMembershipId], references: [id], onDelete: SetNull)
  createdByMembership   Membership                  @relation("AccountingTransactionCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: Cascade)
  lineItems             AccountingTransactionLineItem[]
  ledgerEntries         GeneralLedgerEntry[]

  @@index([organizationId, officeId, type])
  @@index([organizationId, officeId, status])
  @@index([organizationId, relatedTransactionId])
  @@index([organizationId, relatedMembershipId])
  @@index([organizationId, accountingDate])
}

model AccountingTransactionLineItem {
  id                    String                  @id @default(cuid())
  organizationId        String
  officeId              String?
  accountingTransactionId String
  relatedTransactionId  String?
  ledgerAccountId       String
  description           String?
  entrySide             AccountingLineEntrySide
  amount                Decimal                 @db.Decimal(12, 2)
  sortOrder             Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?                 @relation(fields: [officeId], references: [id], onDelete: SetNull)
  accountingTransaction AccountingTransaction   @relation(fields: [accountingTransactionId], references: [id], onDelete: Cascade)
  relatedTransaction    Transaction?            @relation(fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  ledgerAccount         LedgerAccount           @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)

  @@index([organizationId, accountingTransactionId])
  @@index([organizationId, ledgerAccountId])
  @@index([organizationId, relatedTransactionId])
}

model GeneralLedgerEntry {
  id                    String                @id @default(cuid())
  organizationId        String
  officeId              String?
  accountingTransactionId String
  relatedTransactionId  String?
  accountId             String
  entryDate             DateTime
  debitAmount           Decimal               @default(0) @db.Decimal(12, 2)
  creditAmount          Decimal               @default(0) @db.Decimal(12, 2)
  memo                  String?
  createdAt             DateTime              @default(now())
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?               @relation(fields: [officeId], references: [id], onDelete: SetNull)
  accountingTransaction AccountingTransaction @relation(fields: [accountingTransactionId], references: [id], onDelete: Cascade)
  relatedTransaction    Transaction?          @relation(fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  account               LedgerAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([organizationId, officeId, entryDate])
  @@index([organizationId, accountingTransactionId])
  @@index([organizationId, relatedTransactionId])
  @@index([organizationId, accountId])
}

model EarnestMoneyRecord {
  id                    String             @id @default(cuid())
  organizationId        String
  officeId              String?
  transactionId         String
  expectedAmount        Decimal            @db.Decimal(12, 2)
  dueAt                 DateTime
  receivedAmount        Decimal            @default(0) @db.Decimal(12, 2)
  refundedAmount        Decimal            @default(0) @db.Decimal(12, 2)
  paymentDate           DateTime?
  depositDate           DateTime?
  heldByOffice          Boolean            @default(true)
  heldExternally        Boolean            @default(false)
  trackInLedger         Boolean            @default(true)
  status                EarnestMoneyStatus @default(not_received)
  notes                 String?
  createdByMembershipId String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office                Office?            @relation(fields: [officeId], references: [id], onDelete: SetNull)
  transaction           Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  createdByMembership   Membership?        @relation("EarnestMoneyCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  @@unique([transactionId])
  @@index([organizationId, officeId, status])
  @@index([organizationId, dueAt])
}
